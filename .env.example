# Environment Variables — DigicoWorld (Supabase)
# Copia este archivo como .env.local con tus credenciales de Supabase

# Supabase — encontrás esto en: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Contraseña de administrador (simple, para producción usar NextAuth)
NEXT_PUBLIC_ADMIN_PASSWORD=admin123

# Número de WhatsApp del negocio (formato internacional sin +)
NEXT_PUBLIC_WHATSAPP_NUMBER=5491112345678
